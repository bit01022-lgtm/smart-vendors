# Frontend API URL.
# Leave blank for local development if the frontend is served from the same host as the backend.
VITE_API_BASE_URL=https://your-render-service.onrender.com

# Backend secret used by Render.
JWT_SECRET=replace-with-a-secure-secret

# Neon PostgreSQL connection string used by Render.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=verify-full&channel_binding=require